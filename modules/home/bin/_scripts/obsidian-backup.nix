{ pkgs }:
{
  name = "obsidian-backup";
  desc = "Export Obsidian settings + plugins (nixsync) into dotfiles-secrets, API keys blanked";
  usage = "obsidian-backup";
  examples = [
    {
      cmd = "obsidian-backup";
      desc = "Snapshot Main Vault settings into ~/dotfiles-secrets/obsidian/";
    }
    {
      cmd = "OBSIDIAN_VAULT='Work Vault' obsidian-backup";
      desc = "Snapshot a different vault";
    }
  ];
  hostOnly = true;
  runtimeInputs = [
    pkgs.jq
    pkgs.perl
    pkgs.nixfmt
  ];
  bash = ''
    set -euo pipefail

    # Standalone clone of github:joegoldin/dotfiles-secrets; override with
    # DOTFILES_SECRETS (same convention as secret-helper).
    SECRETS_DIR="''${DOTFILES_SECRETS:-$HOME/dotfiles-secrets}"
    VAULT_NAME="''${OBSIDIAN_VAULT:-Main Vault}"
    OUT_FILE="$SECRETS_DIR/obsidian/obsidian.nix"
    SECRET_KEY_RE='api[-_]?key|apikey|token|secret|password|access[-_]?key'

    [ -d "$SECRETS_DIR" ] || die "$SECRETS_DIR not found; clone git@github.com:joegoldin/dotfiles-secrets first"

    # Needs a running Obsidian (>= 1.12) with the `nixsync` community plugin
    # enabled; the obsidian CLI errors out cleanly when the app is down.
    VAULT_PATH=$(obsidian vault="$VAULT_NAME" vault info=path)
    EXPORT_FILE="$VAULT_PATH/obsidian.nix"

    # The palette command returns before the plugin finishes writing, so clear
    # any stale export and poll for the fresh one.
    rm -f "$EXPORT_FILE"
    obsidian vault="$VAULT_NAME" command id=nixsync:export-settings-as-nix > /dev/null
    for _ in $(seq 1 40); do
      [ -s "$EXPORT_FILE" ] && break
      sleep 0.25
    done
    [ -s "$EXPORT_FILE" ] || die "nixsync never wrote $EXPORT_FILE (plugin installed and enabled?)"
    sleep 0.25 # the file can appear before the write is fully flushed

    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT
    tmp="$tmpdir/obsidian.nix"

    {
      echo "# Obsidian vault settings export ($VAULT_NAME) — generated by obsidian-backup (nixsync plugin)."
      echo "# Secret-looking values (API keys, tokens) are blanked; re-enter them after import."
      # The export writes one `key = "value";` per line, so blanking
      # secret-bearing keys line-wise is safe; anything missed is caught by
      # the verification below. tail strips the plugin's dated header, which
      # would otherwise show up as a diff on every run.
      perl -pe 's/^(\s*)(\S*(?:'"$SECRET_KEY_RE"')\S*)(\s*=\s*)"[^"]+";$/$1$2$3"";/i
                and print STDERR "  blanked $2\n"' "$EXPORT_FILE" | tail -n +2
    } > "$tmp"
    nixfmt "$tmp"

    # Refuse to store the export if any secret-looking value survived.
    leaks=$(nix eval --json -f "$tmp" | jq -r --arg re "$SECRET_KEY_RE" '
      paths(scalars) as $p
      | select(($p[-1] | tostring | test($re; "i"))
          and (getpath($p) | type == "string" and length > 0))
      | $p | join(".")')
    [ -z "$leaks" ] || die "sanitize missed secret values: $leaks"

    mkdir -p "$(dirname "$OUT_FILE")"
    cp "$tmp" "$OUT_FILE"
    # Don't leave the raw export (with real keys) sitting in the synced vault.
    rm -f "$EXPORT_FILE"

    green "stored $OUT_FILE"
    git -C "$SECRETS_DIR" status --short -- obsidian/ || true
  '';
}
